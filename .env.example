# ─── Emissary — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# 1. Gemini API Key
#    Get it free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Serper.dev API Key (Google Search API)
#    Get 2,500 free searches at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# 3. Google Sheets Spreadsheet ID
#    Create a blank Google Sheet, copy the ID from the URL:
#    https://docs.google.com/spreadsheets/d/[THIS_PART]/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# 4. Daily send limit (default 15 — conservative safe zone for LinkedIn)
DAILY_SEND_LIMIT=15

# 5. Batch size (sends this many, then waits)
BATCH_SIZE=5

# 6. Min/Max sleep between batches in minutes
BATCH_SLEEP_MIN=15
BATCH_SLEEP_MAX=25

# 7. Your Google Drive resume link (shared publicly / anyone with link can view)
#    Used in the follow-up DM sent to accepted connections.
#    Example: https://drive.google.com/file/d/XXXXXX/view?usp=sharing
RESUME_LINK=https://drive.google.com/your-resume-link-here
